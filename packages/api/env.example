# Database
DATABASE_URL=mysql://app_user:app_password@localhost:3307/express_react_auth

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# reCAPTCHA Configuration (optional - for spam protection)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# JWT Configuration (REQUIRED)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (optional - for password reset emails)
EMAIL_PROVIDER=console
EMAIL_FROM=FormGrid <noreply@formgrid.dev>
RESEND_API_KEY=

# SMTP Configuration (optional - alternative to Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# File Upload Configuration (optional - defaults work out of the box)
FILE_STORAGE_TYPE=local
MAX_FILE_SIZE=10485760
MAX_FILES=10

# Cloud Storage (optional - only configure if not using local storage)
# For AWS S3:
# FILE_STORAGE_TYPE=s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# For Google Cloud Storage:
# FILE_STORAGE_TYPE=gcs
# GCS_BUCKET_NAME=your-bucket-name
# GCS_REGION=us-central1
# GCS_PROJECT_ID=your-project-id

# For MinIO:
# FILE_STORAGE_TYPE=minio
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_BUCKET_NAME=file-uploads
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# App Configuration
APP_URL=http://localhost:4001
PORT=4000
NODE_ENV=development
